DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
JWT_SECRET=change-me-in-production
PORT=3001

# 外部赛果数据源（openfootball worldcup.json）
RESULTS_SYNC_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json
# 赛果同步间隔（毫秒），默认 1 小时
RESULTS_SYNC_INTERVAL_MS=3600000

# 体彩赔率接口（竞彩足球计算器）
ODDS_SYNC_URL=https://webapi.sporttery.cn/gateway/jc/football/getMatchCalculatorV1.qry?poolCode=hhad,had&channel=c
# 赔率同步间隔（毫秒），默认 1 小时
ODDS_SYNC_INTERVAL_MS=3600000
# 无体彩赔率时是否回退模拟算法（设为 false 则仅展示已同步场次）
ODDS_FALLBACK_SIMULATE=true
