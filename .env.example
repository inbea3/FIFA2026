DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
JWT_SECRET=change-me-in-production
PORT=3001

# 外部赛果数据源（openfootball worldcup.json）
RESULTS_SYNC_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json
# 赛果同步间隔（毫秒），默认 1 小时
RESULTS_SYNC_INTERVAL_MS=3600000
